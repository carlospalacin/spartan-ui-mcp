# GitHub Personal Access Token for higher API rate limits (5000/hr vs 60/hr)
# Generate at: https://github.com/settings/tokens
# No special scopes needed for public repos
GITHUB_TOKEN=

# File-based cache TTL in hours (default: 24)
SPARTAN_CACHE_TTL_HOURS=24

# In-memory cache TTL in milliseconds (default: 300000 = 5 minutes)
SPARTAN_CACHE_TTL_MS=300000

# HTTP request timeout in milliseconds (default: 15000)
SPARTAN_FETCH_TIMEOUT_MS=15000
